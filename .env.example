# LLM Provider — ollama | lm_studio | openai | codex | claude
# LM Studio: בחר מודל → הפעל Server (פורט 1234) → העתק את מזהה המודל מלשונית Server ל־JARVIS_OPENAI_MODEL למטה.
# אמבדינגים (זיכרון וקטורי) עדיין דרך Ollama — אפשר להשאיר Ollama רץ ברקע ל־nomic-embed-text בלבד.
# עם codex: השאר JARVIS_OPENAI_API_KEY ריק. עם claude: אם אין API key, משתמש ב-claude CLI (מנוי).
JARVIS_LLM_PROVIDER=
# Ollama — חייב להיות אותו שרת שבו הרצת `ollama pull` (Windows לעומת WSL =
JARVIS_OLLAMA_HOST=
# Chat model — חייב להתאים ל־`ollama list`
# מהירות: qwen2.5:7b (מומלץ) או llama3.2:3b (הכי קטן/מהיר, עברית חלשה יותר). qwen3:8b איטי יותר — הרבה "חשיבה".
# ג'רוויס דורש tools — DictaLM לא מתאים. ראייה: qwen3-vl:8b (החלפה זמנית כשצריך מסך)
JARVIS_OLLAMA_MODEL=
# GPU: -1 =
JARVIS_OLLAMA_NUM_GPU=
# מהירות: מודל קטן יותר =
JARVIS_OLLAMA_NUM_PREDICT=
JARVIS_OLLAMA_NUM_CTX=
JARVIS_OLLAMA_KEEP_ALIVE=
JARVIS_OLLAMA_FALLBACK_ENABLED=
# טיימאאוט לקריאת LLM (שניות). ברירת מחדל 300. אם Ollama נתקע על "Thinking..." >2 דקות — העלה (למשל 600).
JARVIS_LLM_CALL_TIMEOUT_SECONDS=
# Embeddings — Jarvis מנסה כמה שמות אם אחד נכשל; אחרי pull: ollama pull nomic-embed-text
JARVIS_EMBEDDING_MODEL=
# OpenAI / Codex / LM Studio
# LM Studio: מפתח דמה (השרת המקומי בדרך כלל מתעלם). ל-API אמיתי של OpenAI: מפתח מ-platform.openai.com
# Backup only, disabled so Codex OAuth/CLI is used instead of plain OpenAI API:
# JARVIS_OPENAI_API_KEY=
JARVIS_OPENAI_API_KEY=
# מזהה מודל ב-LM Studio =
JARVIS_OPENAI_MODEL=
# ריק עם lm_studio =
JARVIS_OPENAI_BASE_URL=
# כשחוזרים ל-codex: JARVIS_OPENAI_MODEL=
JARVIS_CODEX_CLI_MODEL=
# Anthropic: מפתח ריק =
# API בלבד: https://console.anthropic.com/ → API Keys — הדבק sk-ant-... בלי מרכאות. אחרי שמירה — הפעל מחדש את ג'רוויס.
JARVIS_ANTHROPIC_API_KEY=
# מזהה מודל מלא ל-API (עדכן לפי התיעוד בקונסול אם צריך)
JARVIS_ANTHROPIC_MODEL=
# Spotify (get free credentials from https://developer.spotify.com/dashboard)
JARVIS_SPOTIPY_CLIENT_ID=
JARVIS_SPOTIPY_CLIENT_SECRET=
JARVIS_SPOTIPY_REDIRECT_URI=
# Creality Print
JARVIS_CREALITY_PRINT_EXE=
# Barber
JARVIS_CALMARK_BARBER_NAME=
JARVIS_CALMARK_BARBER_URL=
# false =
JARVIS_CALMARK_PLAYWRIGHT_HEADLESS=
JARVIS_CALMARK_PLAYWRIGHT_SLOW_MO_MS=
# Home Assistant
JARVIS_HA_URL=
JARVIS_HA_TOKEN=
# Apple TV (רשת הבית — AirPlay; Jarvis יכול להשתמש ב־IP הזה לסקילים עתידיים)
JARVIS_APPLE_TV_HOST=
# LG TV (local network — webOS control)
LG_TV_IP=
# Dashboard (real-time web UI at http://127.0.0.1:8550)
JARVIS_DASHBOARD_ENABLED=
JARVIS_DASHBOARD_PORT=
# Voice
JARVIS_VOICE_ENABLED=
# ElevenLabs TTS (https://elevenlabs.io → Profile → API Key)
JARVIS_ELEVENLABS_API_KEY=
# Voice ID — default is "George". Browse voices at https://elevenlabs.io/voice-library
JARVIS_ELEVENLABS_VOICE_ID=
JARVIS_ELEVENLABS_MODEL=
# Telegram
JARVIS_TELEGRAM_TOKEN=
JARVIS_TELEGRAM_ALLOWED_USERS=
# WhatsApp
JARVIS_WHATSAPP_ENABLED=
JARVIS_WHATSAPP_ALLOWED_NUMBERS=
JARVIS_WHATSAPP_API_PORT=
JARVIS_WHATSAPP_ALLOW_GROUPS=
# RuView — WiFi human sensing (presence, vitals, pose via CSI)
JARVIS_RUVIEW_ENABLED=
JARVIS_RUVIEW_URL=
JARVIS_RUVIEW_AUTO_LIGHTS=
JARVIS_DEV_AUTO_RELOAD=
# Pushover (push notifications)
JARVIS_PUSHOVER_USER_KEY=
JARVIS_PUSHOVER_APP_TOKEN=
